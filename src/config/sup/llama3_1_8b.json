{
    "algorithm": "PCNet_Guardrail",
    "device": "cuda",
    "pc_in_channels": 128,

    "llm_models": [
        "meta-llama/Llama-3.1-8B-Instruct"
    ],

    "datasets": [
        {
            "name": "coqa",
            "subset": null
        },
        {
            "name": "truthful_qa",
            "subset": "generation"
        },
        {
            "name": "trivia_qa",
            "subset": "rc.nocontext"
        },
        {
            "name": "rajpurkar/squad_v2",
            "subset": null,
            "split": "test"
        }
    ],

    "max_train_samples": 500,
    "epochs": 50,
    "batch_size": 4,
    "learning_rate": 0.001,
    "pc_weights_path": "checkpoints/PCNet_Guardrail/pcnet_best.pth",
    "mlp_weights_path": "checkpoints/PCNet_Guardrail/mlp_probe_best.pth",
    "note": "meta-llama/Llama-3.1-8B-Instruct"
}
